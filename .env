# Copy to .env and fill real values.  .env is gitignored.

# ---- Postgres (used by docker-compose interpolation & backend) ----
POSTGRES_USER=wc
POSTGRES_PASSWORD=change_me_pg
POSTGRES_DB=worldcup

# ---- Backend ----
# Local dev (running Go on host): point to localhost.
# In docker-compose this is overridden to use host "db".
DATABASE_URL=postgres://wc:change_me_pg@localhost:6573/worldcup?sslmode=disable

# Backend HTTP listen port
PORT=8080

# Password for the host-only Settings + Spin Wheel sections.
SETTINGS_PASSWORD=change_me_admin

# NOTE: the football-data.org token is NOT stored here.
# It's entered in the Settings panel and persisted in the DB (app_settings).
